# Local development defaults. Copy to server/.env if overrides are needed.
NODE_ENV=development
HOST=127.0.0.1
PORT=8000

# Comma-separated exact origins. Development also permits http(s) localhost,
# 127.0.0.1 and [::1] with any port.
CORS_ORIGINS=http://localhost:1420,http://localhost:5173

# Optional for localhost development. When empty, control endpoints only accept
# loopback callers. Set a strong value before exposing the service remotely.
CONTROL_API_KEY=

# Device credentials are short-lived and are stored as SHA-256 hashes in memory.
DEVICE_TOKEN_TTL_SECONDS=86400
WS_HEARTBEAT_INTERVAL_MS=15000
WS_MAX_PAYLOAD_BYTES=1048576
COMMAND_TIMEOUT_MAX_MS=30000

# A non-loopback HOST requires REQUIRE_TLS=true. In a reverse-proxy deployment,
# also enable TRUST_PROXY and forward X-Forwarded-Proto=https.
REQUIRE_TLS=false
TRUST_PROXY=false
